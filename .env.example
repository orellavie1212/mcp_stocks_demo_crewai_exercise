# =============================================================================
# Stock Agent Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For GCP production, values come from Secret Manager (not this file).
# =============================================================================

# --- GCP Project ---
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# --- LLM Provider ---
# "google_ai_studio" (local dev — uses GEMINI_API_KEY below)
# "vertex_ai"        (production on GCP — uses Workload Identity, no key needed)
LLM_PROVIDER=google_ai_studio

# Google AI Studio API Key (only needed for LLM_PROVIDER=google_ai_studio)
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Gemini Model Routing ---
# Cheap model for guardrail checks, routing, classification
GEMINI_FAST_MODEL=gemini-2.5-flash-lite
# Main model for agent tasks (research, technical, sector)
GEMINI_MAIN_MODEL=gemini-2.5-flash
# Strongest model for final synthesis (only used for complex reports)
GEMINI_STRONG_MODEL=gemini-2.5-pro

# --- Service URLs (local docker-compose values) ---
MCP_SERVER_URL=http://mcp-server:8001
JOB_API_URL=http://job-api:8000
AGENT_RUNTIME_URL=http://agent-runtime:8002

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL_SECONDS=3600

# --- Pub/Sub ---
# For local dev with emulator:
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
PUBSUB_PROJECT_ID=local-project
PUBSUB_TOPIC_ANALYSIS_REQUESTS=analysis-requests
PUBSUB_TOPIC_ANALYSIS_DLQ=analysis-dlq
PUBSUB_SUBSCRIPTION_AGENT_WORKER=agent-worker-sub
# Max retries before sending to dead-letter queue
PUBSUB_MAX_RETRIES=3

# --- Firestore ---
# For local dev: uses Firestore emulator or a real GCP Firestore (free tier)
FIRESTORE_PROJECT_ID=your-gcp-project-id
# Leave empty for all 4 labs in this repo:
#   Lab 2/3 → job-api falls back to an in-memory store (no Firestore emulator ships here).
#   Lab 4   → client talks to real Firestore via Workload Identity.
# Only set this if you're running a Firestore emulator separately (e.g. "localhost:8080").
FIRESTORE_EMULATOR_HOST=

# --- Langfuse (LLM Observability) ---
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# Set to "false" to disable Langfuse tracing (e.g., in unit tests)
LANGFUSE_ENABLED=true

# --- Security ---
# Internal token used for service-to-service auth (MCP Server, Job API)
INTERNAL_API_TOKEN=change-me-in-production-use-secret-manager
# Accepted values for the Authorization: Bearer header on public endpoints
# Set to "true" in production
API_AUTH_ENABLED=false

# --- Guardrails ---
# Maximum input query length (characters)
GUARDRAIL_MAX_INPUT_LENGTH=2000
# Maximum tool calls per single crew run
GUARDRAIL_MAX_TOOL_CALLS=30
# Enable/disable prompt injection detection
GUARDRAIL_INJECTION_DETECTION=true

# --- Rate Limiting ---
# Requests per minute per user (enforced via Redis)
RATE_LIMIT_RPM=10
RATE_LIMIT_TOKENS_PER_DAY=100000

# --- Cost Control ---
# Max tokens per LLM response
LLM_MAX_TOKENS=4096
# Request timeout in seconds
LLM_TIMEOUT_SECONDS=120

# --- Logging ---
LOG_LEVEL=INFO
# "json" for production, "text" for local dev readability
LOG_FORMAT=json

# --- Environment ---
# "local" | "staging" | "production"
ENVIRONMENT=local
# overridden per service in docker-compose
SERVICE_NAME=stock-agent

